# =====================================================
# HelpDesk AI — .env
# Variables de entorno del proyecto
# Copia este archivo como .env y rellena los valores
# =====================================================

# ─── PostgreSQL ───────────────────────────────────────
POSTGRES_DB=helpdesk
POSTGRES_USER=helpdesk_user
POSTGRES_PASSWORD=helpdesk_pass123     # ← Cambia esto

# ─── n8n ──────────────────────────────────────────────
N8N_BASIC_AUTH_USER=admin
N8N_BASIC_AUTH_PASSWORD=admin123       # ← Cambia esto
N8N_HOST=localhost                     # ← En producción: tu dominio
N8N_PROTOCOL=http                      # ← En producción: https

# ─── OpenAI ───────────────────────────────────────────
# Esta la configuras DENTRO de n8n como credencial,
# no aquí directamente.
# OPENAI_API_KEY=sk-...

# ─── Telegram ─────────────────────────────────────────
# También se configura dentro de n8n.
# TELEGRAM_BOT_TOKEN=...
# TELEGRAM_CHAT_ID=...

# ─── Zona horaria ─────────────────────────────────────
TZ=America/Bogota